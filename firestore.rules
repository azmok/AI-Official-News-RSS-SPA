rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net (deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for safety and ownership checks
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail(email) {
      return isSignedIn() &&
             request.auth.token.email_verified == true &&
             request.auth.token.email == email;
    }

    function isSystemAuthorized() {
      // Allow the specified user: gentakanashi0425@gmail.com
      return isVerifiedEmail("gentakanashi0425@gmail.com");
    }

    // Rules for Sources
    match /sources/{sourceId} {
      allow read, write: if isSystemAuthorized();
    }

    // Rules for Seen Articles
    match /seen_articles/{articleId} {
      allow read, write: if isSystemAuthorized();
    }
  }
}
