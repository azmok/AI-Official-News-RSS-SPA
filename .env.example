# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Optional. Resend API token for email dispatches.
RESEND_API_KEY=""

# GMAIL_USER: Optional. Gmail address for SMTP dispatches.
GMAIL_USER=""

# GMAIL_PASS: Optional. Google App Password (not your standard password).
GMAIL_PASS=""

# CHECK_SECRET: Optional. A secret security token validating Cloud Scheduler cron triggers.
CHECK_SECRET="some-secure-random-phrase-goes-here"

# FIREBASE_SERVICE_ACCOUNT: Optional but highly recommended if Firestore permission is missing for standard container credentials.
# Set this to the full JSON string of your Firebase Service Account Private Key generated from Firebase Console -> Service Accounts.
FIREBASE_SERVICE_ACCOUNT=""

# NOTIFICATION_EMAIL: Optional. Change target recipient email for updates (Defaults to gentakanashi0425@gmail.com).
NOTIFICATION_EMAIL=""
